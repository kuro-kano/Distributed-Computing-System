# Host dev (`npm run dev`): point at a MongoDB reachable from your machine.
MONGODB_URI=mongodb://localhost:27017/taskboard

# Docker Compose (`docker compose up`): no change needed — docker-compose.yml
#   overrides MONGODB_URI to the `mongo` service hostname automatically.
#
# Production (web server -> separate DB server): set the DB server's IP, e.g.
#   MONGODB_URI=mongodb://<DB_SERVER_IP>:27017/taskboard
